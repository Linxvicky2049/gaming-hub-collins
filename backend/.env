# Railway Production Environment Variables
PORT=8000
NODE_ENV=production

# Database
# Railway will automatically provide DATABASE_URL for PostgreSQL
# For now using SQLite, but can be changed to PostgreSQL later

# JWT Secret (change this in production!)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# CORS Origins (add your Vercel domain when deployed)
CORS_ORIGINS=https://your-vercel-app.vercel.app,http://localhost:3000,http://localhost:3001